{
  "name": "@differ/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "build": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote --env production",
    "db:seed:gen": "node --experimental-strip-types scripts/import-puzzles.ts",
    "db:seed:local": "pnpm db:seed:gen && wrangler d1 execute DB --local --file=scripts/seed/puzzles.sql",
    "db:seed:prod": "pnpm db:seed:gen && wrangler d1 execute DB --remote --env production --file=scripts/seed/puzzles.sql",
    "test:rl:smoke": "node --test --experimental-strip-types tests/rate-limit.smoke.test.ts",
    "test:rl:k6": "k6 run tests/k6/rate-limit.js"
  },
  "dependencies": {
    "@differ/shared": "workspace:*",
    "@noble/hashes": "^2.2.0",
    "@tsndr/cloudflare-worker-jwt": "^3.1.4",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.9",
    "otpauth": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^20.16.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.85.0"
  }
}
