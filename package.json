{
  "name": "differ",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "pnpm -F @differ/server dev",
    "dev:client": "pnpm -F @differ/client dev",
    "dev:tailworker": "pnpm -F @differ/tail-worker dev",
    "dev:workers": "pnpm -F @differ/server exec wrangler dev --local --persist-to .wrangler/state -c wrangler.toml -c ../tail-worker/wrangler.toml",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=25",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.0.4"
}
